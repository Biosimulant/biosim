<model xmlns="http://www.cellml.org/cellml/1.1#" name="small_decay">
  <units name="per_second">
    <unit units="second" exponent="-1"/>
  </units>
  <component name="main">
    <variable name="t" units="second" public_interface="out"/>
    <variable name="x" units="dimensionless" initial_value="1"/>
    <variable name="k" units="per_second" initial_value="1"/>
    <math xmlns="http://www.w3.org/1998/Math/MathML">
      <apply>
        <eq/>
        <apply>
          <diff/>
          <bvar>
            <ci>t</ci>
          </bvar>
          <ci>x</ci>
        </apply>
        <apply>
          <minus/>
          <apply>
            <times/>
            <ci>k</ci>
            <ci>x</ci>
          </apply>
        </apply>
      </apply>
    </math>
  </component>
</model>
